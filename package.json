{
  "name": "openlane-ui",
  "version": "1.0.0",
  "description": "A monorepo for openlane UI apps and supporting libraries",
  "repository": "git@github.com:theopenlane/openlane-ui.git",
  "author": "openlane <info@theopenlane.io>",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "debug": "turbo debug",
    "type-check": "turbo type-check",
    "clean": "rm -rf node_modules/** && rm -rf ./apps/console/.next && rm -rf ./apps/console/node_modules && rm -rf ./apps/storybook/.next && rm -rf ./apps/storybook/node_modules &&  rm -rf ./packages/*/node_modules",
    "turbo-clean": "turbo clean",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,scss,json,yaml,yml,md,graphql,gql}": "prettier --write",
    "apps/console/**/*.{js,jsx,ts,tsx}": "eslint --no-warn-ignored --max-warnings=0 --fix"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@graphql-codegen/typescript-react-query": "^7.0.5",
    "@types/dompurify": "^3.2.0",
    "dompurify": "^3.4.11",
    "dotenv-cli": "^11.0.0",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "latest",
    "turbo": "^2.10.4"
  },
  "engines": {
    "node": "24.18.x"
  },
  "packageManager": "bun@1.2.16",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "trustedDependencies": [
    "core-js"
  ],
  "resolutions": {
    "react": "19.2.7",
    "node-fetch": "^3.3.2",
    "protobufjs": "^7.6.5",
    "shell-quote": "^1.9.0",
    "@grpc/grpc-js": "^1.14.4",
    "@xmldom/xmldom": "^0.9.0",
    "axios": "^1.18.1",
    "undici": "^6.27.0",
    "fast-uri": "^3.1.3",
    "fast-xml-parser": "^5.9.3",
    "fast-xml-builder": "^1.2.1",
    "form-data": "^4.0.6",
    "next": "16.2.10",
    "effect": "^3.21.4",
    "ws": "^8.21.0",
    "vite": "^8.1.4",
    "postcss": "^8.5.16",
    "dompurify": "^3.4.11"
  },
  "peerDependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@google-cloud/aiplatform": "^6.8.1",
    "@google-cloud/storage": "^7.21.0",
    "@google/genai": "^2.0.0",
    "@platejs/docx-io": "^52.3.10",
    "@radix-ui/react-icons": "^1.3.2",
    "@react-pdf/renderer": "^4.5.1",
    "@turbo/codemod": "^2.10.4",
    "@types/file-saver": "^2.0.7",
    "@xyflow/react": "^12.11.2",
    "docx": "^9.7.1",
    "emoji-mart": "^5.6.0",
    "file-saver": "^2.0.5",
    "google-auth-library": "^10.9.0"
  }
}
