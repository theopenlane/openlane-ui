{
  "name": "openlane-ui",
  "version": "1.0.0",
  "description": "A monorepo for openlane UI apps and supporting libraries",
  "repository": "git@github.com:theopenlane/openlane-ui.git",
  "author": "openlane <info@theopenlane.io>",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "debug": "turbo debug",
    "type-check": "turbo type-check",
    "clean": "rm -rf node_modules/** && rm -rf ./apps/console/.next && rm -rf ./apps/console/node_modules && rm -rf ./apps/storybook/.next && rm -rf ./apps/storybook/node_modules",
    "turbo-clean": "turbo clean",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,scss,json,yaml,yml,md,graphql,gql}": "prettier --write",
    "apps/console/**/*.{js,jsx,ts,tsx}": "eslint --no-warn-ignored --max-warnings=0 --fix"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@graphql-codegen/typescript-react-query": "^7.0.0",
    "@types/dompurify": "^3.2.0",
    "dompurify": "^3.3.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "latest",
    "turbo": "^2.9.4"
  },
  "engines": {
    "node": "24.14.x"
  },
  "packageManager": "bun@1.2.16",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "trustedDependencies": [
    "core-js"
  ],
  "resolutions": {
    "react": "19.2.4",
    "gaxios": "^7.0.0",
    "node-fetch": "^3.3.2"
  },
  "peerDependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@google-cloud/aiplatform": "^6.0.0",
    "@google-cloud/storage": "^7.18.0",
    "@google/genai": "^1.48.0",
    "@radix-ui/react-icons": "^1.3.0",
    "@react-pdf/renderer": "^4.3.2",
    "@turbo/codemod": "^2.5.4",
    "@types/file-saver": "^2.0.7",
    "@xyflow/react": "^12.10.1",
    "docx": "^9.5.1",
    "emoji-mart": "^5.6.0",
    "file-saver": "^2.0.5",
    "google-auth-library": "^10.5.0"
  }
}
